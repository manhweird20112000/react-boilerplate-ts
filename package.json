{
  "name": "w3rd-codebase",
  "version": "1.0.41",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "npx prettier --write . && eslint .",
    "lint:check": "prettier --check . && eslint .",
    "lint:ci": "eslint src",
    "test:unit": "vitest run",
    "docker:build": "docker compose --env-file .env.docker build",
    "docker:up": "bash scripts/docker-deploy.sh deploy",
    "docker:down": "bash scripts/docker-deploy.sh down",
    "docker:restart": "bash scripts/docker-deploy.sh restart",
    "docker:logs": "bash scripts/docker-deploy.sh logs",
    "docker:status": "bash scripts/docker-deploy.sh status",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "storybook": "NODE_OPTIONS=\"--require ./scripts/disable-pnp.cjs\" storybook dev -p 6006",
    "build-storybook": "NODE_OPTIONS=\"--require ./scripts/disable-pnp.cjs\" storybook build"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@ant-design/icons": "^6.2.2",
    "@ant-design/pro-components": "^2.8.10",
    "@base-ui/react": "^1.3.0",
    "@fontsource/inter": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@platejs/basic-nodes": "^52.3.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@udecode/plate-alignment": "^49.0.0",
    "@udecode/plate-link": "^49.0.0",
    "@udecode/plate-list": "^49.0.0",
    "antd": "^6.3.7",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "facehash": "^0.1.0",
    "i18next": "^26.0.3",
    "i18next-http-backend": "^3.0.4",
    "js-cookie": "^3.0.5",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "platejs": "^52.3.21",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^17.0.2",
    "react-json-view": "^1.21.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.2",
    "redux-saga": "^1.4.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
