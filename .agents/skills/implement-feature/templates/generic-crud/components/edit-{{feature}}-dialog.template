import { message } from 'antd'
import { useCallback, useMemo, useRef, type ReactElement } from 'react'
import { useTranslation } from 'react-i18next'

import { extractFormErrors } from '@/shared/lib/form-errors'
import { getResponseMessage, translateResponseMessage } from '@/shared/lib/response'
import { AdaptiveFormDialog } from '@/shared/ui/adaptive-form-dialog'
import { use{{Feature}}Detail } from '../hooks/use-{{feature}}-detail'
import { useUpdate{{Feature}} } from '../hooks/use-update-{{feature}}'
import type { {{Feature}}FormValues } from '../types/{{feature}}-form.type'
import { {{Feature}}Form, type {{Feature}}FormHandle } from './{{feature}}-form'

export type Edit{{Feature}}DialogProps = {
  readonly open: boolean
  readonly {{featureCamel}}Id: string
  readonly onClose: () => void
}

export function Edit{{Feature}}Dialog({
  open,
  {{featureCamel}}Id,
  onClose
}: Edit{{Feature}}DialogProps): ReactElement {
  const { t } = useTranslation()
  const formRef = useRef<{{Feature}}FormHandle>(null)
  const update{{Feature}} = useUpdate{{Feature}}()
  const { data: {{featureCamel}}, isLoading } = use{{Feature}}Detail(open ? {{featureCamel}}Id : null)
  const defaultValues = useMemo<{{Feature}}FormValues | undefined>(
    () =>
      {{featureCamel}}
        ? {
            name: {{featureCamel}}.name,
            description: {{featureCamel}}.description,
            is_enabled: {{featureCamel}}.is_enabled
          }
        : undefined,
    [{{featureCamel}}]
  )

  const handleSubmit = useCallback(
    async (values: {{Feature}}FormValues) => {
      try {
        await update{{Feature}}.mutateAsync({ id: {{featureCamel}}Id, data: values })
        message.success(t('{{featurePluralCamel}}.messages.updateSuccess'))
        onClose()
      } catch (error) {
        const formErrors = extractFormErrors(error)
        if (formErrors && formRef.current?.setServerErrors(formErrors)) {
          throw new Error('submit_failed', { cause: error })
        }
        const responseMessage = translateResponseMessage(getResponseMessage(error), t)
        message.error(responseMessage ?? t('{{featurePluralCamel}}.messages.updateFailed'))
        throw new Error('submit_failed', { cause: error })
      }
    },
    [{{featureCamel}}Id, onClose, t, update{{Feature}}]
  )

  const handleOk = useCallback(async () => {
    try {
      const values = await formRef.current!.submit()
      await handleSubmit(values)
    } catch {
      return Promise.reject(new Error('validation_or_submit_failed'))
    }
  }, [handleSubmit])

  return (
    <AdaptiveFormDialog
      cancelButtonProps={{ disabled: update{{Feature}}.isPending }}
      cancelText={t('actions.cancel')}
      closable={!update{{Feature}}.isPending}
      confirmLoading={update{{Feature}}.isPending}
      destroyOnClose
      maskClosable={!update{{Feature}}.isPending}
      okButtonProps={{ disabled: !defaultValues || isLoading }}
      okText={t('actions.save')}
      onClose={onClose}
      onOk={handleOk}
      open={open}
      title={t('{{featurePluralCamel}}.editTitle')}
    >
      {defaultValues ? <{{Feature}}Form ref={formRef} defaultValues={defaultValues} /> : null}
    </AdaptiveFormDialog>
  )
}
