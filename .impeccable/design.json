  "narrative": {
    "northStar": "The Precision Console",
    "overview": "This system is built for internal operators working quickly through dense information. It rewards accuracy and speed through consistent structure, predictable component behavior, and high-clarity states. It should feel like a well-tuned instrument, not a decorative theme.\n\nThis project explicitly rejects a Bootstrap-like, border-heavy, dated look. Borders exist, but they are thin, quiet, and always subordinate to hierarchy.",
    "keyCharacteristics": [
      "Dense by default, readable by design.",
      "Familiar patterns, no invented affordances.",
      "State clarity over decoration.",
      "Restrained accent usage, focus and selection are the signal."
    ],
    "rules": [
      {
        "name": "The Signal-Only Accent Rule",
        "body": "The brand accent is not decoration. Use it only for primary intent (CTA), selection, focus rings, and semantic emphasis where ambiguity would cost time.",
        "section": "colors"
      },
      {
        "name": "The Small-Type Discipline Rule",
        "body": "Labels stay small and calm. Use weight and spacing for clarity, never oversized type for authority.",
        "section": "typography"
      },
      {
        "name": "The Modal Wins Rule",
        "body": "When a dialog or sheet is open, the overlay and surface elevation must clearly establish a new interaction layer.",
        "section": "elevation"
      }
    ],
    "dos": [
      "Do keep accent usage restrained and functional (focus, selection, primary actions).",
      "Do use thin, quiet borders for separation, not to “decorate” the UI.",
      "Do ship complete interaction states: hover, focus-visible, active, disabled, loading, error."
    ],
    "donts": [
      "Don't drift into a Bootstrap-like UI (heavy borders, coarse spacing, dated feel).",
      "Don't use gradient text, decorative glass blur, or “stripe borders” as accents."
    ]
  }
