      "description": "Backdrop establishes modality without decoration.",
      "html": "<div class=\"ds-overlay\"><div class=\"ds-modal\"><div class=\"ds-modal-title\">Dialog title</div><div class=\"ds-modal-body\">Dense content stays readable. The overlay is the separation.</div><div class=\"ds-modal-actions\"><button class=\"ds-btn ds-btn-outline\">Close</button><button class=\"ds-btn ds-btn-primary\">Confirm</button></div></div></div>",
      "css": ".ds-overlay{position:relative;min-height:220px;padding:16px;border-radius:14px;background:linear-gradient(180deg,rgba(0,0,0,.02),rgba(0,0,0,.04));display:flex;align-items:center;justify-content:center}.ds-overlay:before{content:\"\";position:absolute;inset:0;border-radius:14px;background:rgba(19,30,41,.35);backdrop-filter:blur(8px)}.ds-modal{position:relative;z-index:1;width:min(520px,100%);border-radius:14px;background:#FFFFFF;color:#131E29;box-shadow:0 18px 60px -24px rgba(0,0,0,0.35),0 8px 24px -14px rgba(0,0,0,0.25);border:1px solid rgba(229,229,229,.9);padding:16px;font-family:\"72\",Inter,system-ui,-apple-system,BlinkMacSystemFont,\"Segoe UI\",sans-serif}.ds-modal-title{font-weight:600;font-size:1rem;line-height:1.35;margin:0 0 8px}.ds-modal-body{font-size:.875rem;line-height:1.5;color:rgba(85,107,130,.95)}.ds-modal-actions{margin-top:14px;display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap}"
