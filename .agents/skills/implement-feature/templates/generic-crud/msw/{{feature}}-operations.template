import type { FormErrors, PaginatedData } from '@/shared/types/common'
import { {{FEATURE}}_SERVICE_MESSAGES } from '../constants/{{feature}}-messages'
import type { {{Feature}}Payload } from '../types/{{feature}}-payload.type'
import type { {{Feature}} } from '../types/{{feature}}.type'
import { paginate{{FeaturePlural}} } from '../utils/{{feature}}-query'
import {
  insert{{Feature}},
  remove{{Feature}},
  update{{Feature}},
  {{featureCamel}}Db
} from './{{feature}}-db'
import { validate{{Feature}}Payload } from './{{feature}}-validation'

type SuccessResult<T> = {
  readonly ok: true
  readonly data: T
}

type FailureResult = {
  readonly ok: false
  readonly message: string
  readonly errors?: FormErrors
}

export function list{{Feature}}Records(params?: Record<string, unknown>): PaginatedData<{{Feature}}> {
  return paginate{{FeaturePlural}}({{featureCamel}}Db.{{featurePluralCamel}}, params)
}

export function get{{Feature}}Record(id: string): {{Feature}} | null {
  return {{featureCamel}}Db.{{featurePluralCamel}}.find((item) => item.id === id) ?? null
}

export function create{{Feature}}Record(data: {{Feature}}Payload): SuccessResult<{{Feature}}> | FailureResult {
  const errors = validate{{Feature}}Payload(data)
  if (errors) {
    return { ok: false, message: {{FEATURE}}_SERVICE_MESSAGES.validationFailed, errors }
  }

  return { ok: true, data: insert{{Feature}}(data) }
}

export function update{{Feature}}Record(
  id: string,
  data: {{Feature}}Payload
): SuccessResult<{{Feature}}> | FailureResult {
  const current = get{{Feature}}Record(id)
  if (!current) {
    return { ok: false, message: {{FEATURE}}_SERVICE_MESSAGES.notFound }
  }

  const errors = validate{{Feature}}Payload({ ...current, ...data }, { excludeId: id })
  if (errors) {
    return { ok: false, message: {{FEATURE}}_SERVICE_MESSAGES.validationFailed, errors }
  }

  const updated = update{{Feature}}(id, data)
  return updated ? { ok: true, data: updated } : { ok: false, message: {{FEATURE}}_SERVICE_MESSAGES.notFound }
}

export function delete{{Feature}}Record(id: string): SuccessResult<boolean> | FailureResult {
  return remove{{Feature}}(id)
    ? { ok: true, data: true }
    : { ok: false, message: {{FEATURE}}_SERVICE_MESSAGES.notFound }
}
