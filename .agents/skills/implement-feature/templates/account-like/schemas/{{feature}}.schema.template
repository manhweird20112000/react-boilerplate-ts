import { useMemo } from 'react'
import { useTranslation } from 'react-i18next'
import { z } from 'zod'

import type { {{Feature}}FormValues } from '../types/{{feature}}-form.type'

export function use{{Feature}}Schema() {
  const { t } = useTranslation()
  return useMemo(
    () =>
      z.object({
        email: z
          .string()
          .min(1, t('validation.required', { _field_: t('{{featurePluralCamel}}.fields.email') }))
          .email(t('validation.email')),
        name: z
          .string()
          .min(1, t('validation.required', { _field_: t('{{featurePluralCamel}}.fields.name') }))
          .max(100, t('validation.max', { _field_: t('{{featurePluralCamel}}.fields.name'), _length_: 100 })),
        status: z.enum(['active', 'inactive']),
        role: z.enum(['admin', 'staff'])
      }) satisfies z.ZodType<{{Feature}}FormValues>,
    [t]
  )
}

export type {{Feature}}SchemaValues = z.infer<ReturnType<typeof use{{Feature}}Schema>>
