    "vite": "^8.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "react-router-dom": ">=7"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
