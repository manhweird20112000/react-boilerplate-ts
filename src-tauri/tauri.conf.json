{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "W3RD Codebase",
  "version": "1.0.41",
  "identifier": "com.w3rd.codebase",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:9999",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "W3RD Codebase",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
